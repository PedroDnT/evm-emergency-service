# ========================================
# EVM Emergency Service - API Configuration
# ========================================

# API Server
PORT=3000
NODE_ENV=development

# CORS Configuration
# In production, set this to your frontend domain
CORS_ORIGIN=*

# Blockchain RPC
BASE_RPC_URL=https://mainnet.base.org
# Optional: MEV-protected RPC for private transaction submission
# BASE_PRIVATE_RPC_URL=https://lb.drpc.org/ogrpc?network=base&dkey=YOUR_KEY

# Sponsor Wallet (your service wallet that provides ETH for gas)
# This wallet needs ETH to fund the rescue operations
SPONSOR_ADDRESS=0xYourSponsorWalletAddress
PRIVATE_KEY_SPONSOR=your_sponsor_private_key_here

# Fee Collection
SERVICE_FEE_PERCENTAGE=5
SERVICE_WALLET_ADDRESS=0xYourFeeCollectionWalletAddress

# Rate Limiting (optional overrides)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=5
